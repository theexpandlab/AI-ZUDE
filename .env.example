# The Offer Blueprint — environment variables
# Copy to .env.local for local dev; set the same in Vercel project settings.
# NEVER commit real secrets. Only NEXT_PUBLIC_* values reach the browser.

# ── AI (Anthropic) ────────────────────────────────────────────────
# Server-side only. Without this the app uses the rules-based fallback.
ANTHROPIC_API_KEY=
# Optional override; defaults to claude-sonnet-4-6
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Supabase (Postgres + admin auth) ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side ONLY — full DB access, bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ── Transactional email (Resend) ──────────────────────────────────
RESEND_API_KEY=
# Must be a verified sending domain (SPF/DKIM/DMARC) — PRD §6.6, decision §13.
EMAIL_FROM=The Expand Lab <hey@theexpandlab.com>
# Optional reply-to
EMAIL_REPLY_TO=

# ── CRM sync (GoHighLevel) ────────────────────────────────────────
# Private Integration / API token + the GHL location (sub-account) id.
GHL_API_KEY=
GHL_LOCATION_ID=

# ── Scheduling (Cal.com) ──────────────────────────────────────────
# Public booking link shown on results + in the email.
NEXT_PUBLIC_CAL_BOOKING_URL=https://cal.com/expandlab/10k-business-foundation
# Optional: shared secret to verify the Cal BOOKING_CREATED webhook.
CAL_WEBHOOK_SECRET=

# ── Privacy + site ────────────────────────────────────────────────
NEXT_PUBLIC_PRIVACY_POLICY_URL=https://theexpandlab.com/privacy
NEXT_PUBLIC_SITE_URL=https://build.theexpandlab.com
