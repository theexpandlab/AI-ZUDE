# Meta Ads Setup skill — credentials
# Copy the values you need into your shell/session env before running the
# scripts. NEVER commit real tokens.
#
#   export META_ACCESS_TOKEN="EAAB..."
#   export META_AD_ACCOUNT_ID="act_1234567890"
#
# How to get these (one-time setup):
#   1. In Meta Business Suite, create/choose a Business, an Ad Account, and a
#      Facebook Page. Link an Instagram account to the Page if you want IG ads.
#   2. At developers.facebook.com, create an App (type: Business) and add the
#      "Marketing API" product.
#   3. Generate a long-lived / System User access token with these scopes:
#         ads_management, ads_read, business_management, pages_show_list,
#         pages_read_engagement
#      A System User token (Business Settings → Users → System Users) is best —
#      it doesn't expire like a personal token.
#   4. Run `python3 scripts/preflight.py` to confirm the token and list your
#      ad account / Page / Instagram ids.

# Required — long-lived user or (preferred) System User token
META_ACCESS_TOKEN=

# Default ad account (a brief's account.ad_account_id overrides this)
META_AD_ACCOUNT_ID=act_

# Default Facebook Page ads run under (brief's account.page_id overrides)
META_PAGE_ID=

# Optional — Instagram account id for IG placements
META_INSTAGRAM_ACTOR_ID=

# Optional — pin the Graph API version (defaults to v21.0)
META_API_VERSION=v21.0
