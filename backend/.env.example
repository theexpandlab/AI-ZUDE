# --- Server ---
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# --- Auth ---
# 32+ random bytes. Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Postgres ---
DATABASE_URL=postgres://capture:capture@localhost:5432/capture

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Storage ---
# 'local' uses ./var/storage on disk (dev). 's3' uses the S3-compatible config below.
STORAGE_DRIVER=local
LOCAL_STORAGE_DIR=./var/storage
# Base URL for presigned local uploads (used only when STORAGE_DRIVER=local).
LOCAL_STORAGE_BASE_URL=http://localhost:4000

S3_REGION=us-east-1
S3_BUCKET=capture-chunks
# For MinIO / R2 / LocalStack:
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_KMS_KEY_ID=

# --- OpenAI / Whisper ---
# Required for the transcription worker. Leave blank to skip transcription.
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1

# --- Operations ---
# How long after engagement ends until raw captures auto-delete (days).
RAW_RETENTION_DAYS=30
# Default retention for processed outputs (days). Configurable per engagement.
PROCESSED_RETENTION_DAYS=90
# SLA for explicit deletion requests (hours). Spec §5.5 = 24h.
DELETION_SLA_HOURS=24
