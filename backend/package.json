{
  "name": "workday-capture-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Cloud ingestion + processing API for the Workday Capture & Audit Engine",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:workers": "tsx watch src/workers/index.ts",
    "start": "node dist/index.js",
    "start:workers": "node dist/workers/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate:generate": "drizzle-kit generate",
    "migrate:run": "tsx scripts/migrate.ts",
    "seed": "tsx scripts/seed.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.0",
    "@aws-sdk/s3-request-presigner": "^3.658.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/multipart": "^9.0.0",
    "@fastify/sensible": "^6.0.1",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.20.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.34.0",
    "fastify": "^5.0.0",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.1",
    "openai": "^4.67.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "postgres": "^3.4.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.14.10",
    "drizzle-kit": "^0.25.0",
    "tsx": "^4.19.1",
    "typescript": "^5.5.3",
    "vitest": "^2.1.1"
  }
}
